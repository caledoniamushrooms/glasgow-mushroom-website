---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
  showFooter?: boolean;
}

const {
  title,
  description = 'Glasgow Mushroom Company — Gourmet mushrooms grown in Glasgow.',
  showNav = true,
  showFooter = true,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL('/og-card.jpg', Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Glasgow Mushroom Company" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Glasgow Mushroom Company — gourmet mushrooms grown in Glasgow" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Abhaya+Libre:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NWCMVQ24FD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NWCMVQ24FD');
    </script>
  </head>
  <body>
    {showNav && <Header />}
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}
    <CookieBanner />
    <script is:inline>
      function initReveal() {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(function(el) {
          obs.observe(el);
        });
      }
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
