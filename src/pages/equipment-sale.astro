---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import AssetBrowser from '../components/assets/AssetBrowser.tsx';
import { createClient } from '@supabase/supabase-js';
import '../styles/portal-tailwind.css';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseAnonKey);

const { data: listingsRaw, error: listingsError } = await supabase
  .from('asset_listings')
  .select('id, name, description, asking_price, category, status, allow_offers, is_poa, is_zero_rated, sort_order, asset_listing_images(id, storage_path, position)')
  .eq('is_hidden', false)
  .order('sort_order')
  .order('created_at', { ascending: false });

if (listingsError) {
  console.error('equipment-sale: asset_listings fetch failed:', listingsError);
}

// asking_price: null means the price is TBD — keep it null, don't coerce
// (Number(null) === 0 would make unpriced items render as "Free").
const listings = (listingsRaw ?? []).map((l: any) => ({
  ...l,
  asking_price: l.asking_price == null ? null : Number(l.asking_price),
  asset_listing_images: (l.asset_listing_images ?? []).sort(
    (a: any, b: any) => a.position - b.position,
  ),
}));

const imageBase = `${supabaseUrl}/storage/v1/object/public/asset-images`;
---

<BaseLayout
  title="Equipment for sale — Glasgow Mushroom Company"
  description="As Glasgow Mushroom Company winds down, our growing, sterilisation, cold-chain and office equipment is available for sale. Browse listings and register your interest."
>
  <section class="eq-table-section">
    <div class="eq-table-container">
      {listingsError ? (
        <div class="eq-error">
          <h1>Equipment for sale</h1>
          <p>
            The equipment sale is temporarily unavailable — please try again in a
            few minutes, or email
            <a href="mailto:hello@glasgowmushroomcompany.co.uk">hello@glasgowmushroomcompany.co.uk</a>.
          </p>
        </div>
      ) : (
        <AssetBrowser client:load listings={listings} imageBase={imageBase} />
      )}
    </div>
  </section>
</BaseLayout>

<style is:global>
  body { background-color: #fafaf7 !important; color: #1c1917 !important; }

  .eq-table-section {
    padding: 3rem 0 5rem;
    overflow-x: clip;
  }
  .eq-table-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .eq-error {
    text-align: center;
    padding: 4rem 1rem;
  }
  .eq-error h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .eq-error a {
    text-decoration: underline;
  }
  @media (min-width: 640px) {
    .eq-table-section { padding: 3rem 1rem 5rem; }
  }
  @media (min-width: 768px) {
    .eq-table-section { padding: 4rem 2rem 6rem; }
  }
</style>
