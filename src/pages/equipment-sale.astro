---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import AssetBrowser from '../components/assets/AssetBrowser.tsx';
import { createClient } from '@supabase/supabase-js';
import '../styles/portal-tailwind.css';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseAnonKey);

const { data: listingsRaw } = await supabase
  .from('asset_listings')
  .select('id, name, description, asking_price, category, status, sort_order, asset_listing_images(id, storage_path, position)')
  .order('sort_order')
  .order('created_at', { ascending: false });

const listings = (listingsRaw ?? []).map((l: any) => ({
  ...l,
  asking_price: Number(l.asking_price),
  asset_listing_images: (l.asset_listing_images ?? []).sort(
    (a: any, b: any) => a.position - b.position,
  ),
}));

const imageBase = `${supabaseUrl}/storage/v1/object/public/asset-images`;
---

<BaseLayout
  title="Equipment for sale — Glasgow Mushroom Company"
  description="As Glasgow Mushroom Company winds down, our growing, sterilisation, cold-chain and office equipment is available for sale. Browse listings and register your interest."
>
  <section class="eq-sale-page">
    <div class="eq-sale-container">
      <header class="eq-sale-header">
        <h1>Equipment for sale</h1>
      </header>

      <AssetBrowser client:load listings={listings} imageBase={imageBase} />
    </div>
  </section>
</BaseLayout>

<style is:global>
  body { background-color: #fafafa !important; color: #18181b !important; }
  .eq-sale-page { padding: 3rem 1rem 5rem; }
  .eq-sale-container { max-width: 1100px; margin: 0 auto; }
  .eq-sale-header { margin-bottom: 2rem; }
  .eq-sale-header h1 {
    font-family: 'Abhaya Libre', serif;
    font-size: 2.5rem;
    line-height: 1.1;
    margin: 0 0 0.75rem;
    color: #18181b;
  }
  .eq-sale-header p {
    max-width: 64ch;
    color: #52525b;
    line-height: 1.6;
  }
  @media (min-width: 768px) {
    .eq-sale-page { padding: 4rem 2rem 6rem; }
    .eq-sale-header h1 { font-size: 3rem; }
  }
</style>
