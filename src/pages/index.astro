---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';
import splashHeroSrc from '../assets/images/splash-hero.jpg';

const splashHero = await getImage({ src: splashHeroSrc, format: 'webp', quality: 80, width: 1920 });
---

<BaseLayout title="Glasgow Mushroom Company" showNav={false} showFooter={false}>
  <section class="splash" style={`--bg: url('${splashHero.src}')`}>
    <div class="splash__content">
      <img src="/images/logo-full.svg" alt="Glasgow Mushroom Company" class="splash__logo" />
      <a href="/home" class="splash__enter">Enter</a>
    </div>
  </section>
</BaseLayout>

<style>
  .splash {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .splash__content {
    text-align: center;
    padding: 2rem;
  }

  .splash__logo {
    width: 250px;
    height: auto;
    margin-bottom: 2.5rem;
    filter: brightness(0) invert(1);
    animation: fadeUp 0.9s ease forwards;
  }

  .splash__enter {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: #000;
    background-color: #fff;
    padding: 9px 10px;
    border: none;
    border-radius: 6px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.3s forwards;
    transition: opacity 0.2s ease;
  }

  .splash__enter:hover {
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    .splash__logo {
      width: 500px;
    }

    .splash__tagline {
      font-size: 2rem;
    }
  }
</style>
