---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Glasgow Mushroom Company" showNav={false} showFooter={false}>
  <section class="splash">
    <div class="splash__content">
      <h1>Glasgow Mushroom Company</h1>
      <a href="/home" class="splash__enter">Enter</a>
    </div>
  </section>
</BaseLayout>

<style>
  .splash {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/splash-hero.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
  }

  .splash::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(4, 4, 4, 0.6);
  }

  .splash__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
  }

  .splash__content h1 {
    margin-bottom: 2rem;
  }

  .splash__enter {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    padding: 0.75rem 2.5rem;
    border: 2px solid var(--color-text);
    color: var(--color-text);
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .splash__enter:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }
</style>
