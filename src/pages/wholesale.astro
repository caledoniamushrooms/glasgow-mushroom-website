---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wholesale — Glasgow Mushroom Company" description="Wholesale and distribution enquiries for Glasgow Mushroom Company.">
  <section class="ws-hero">
    <h1>Wholesale</h1>
  </section>

  <section class="ws-content section">
    <div class="container">
      <div class="ws-intro">
        <h2>Wholesale & Distribution</h2>
        <p>Please email us for Glasgow and the surrounding areas. Alternatively, for enquiries further afield please find details of distributors we partner with below:</p>
      </div>

      <article class="distributor-section">
        <img src="/images/distributors/coeur-sauvage.png" alt="Coeur Sauvage" class="distributor-section__logo" loading="lazy" />
        <h3>Coeur Sauvage</h3>
        <p class="distributor-section__description">We're proud to supply Coeur Sauvage, whose deep knowledge and passion for Scotland's wild larder shine through everything they do. Specialists in foraged and seasonal produce, they bring together the best of Scotland's woodlands, coasts, and farms to serve chefs and restaurants who care about provenance and flavour.</p>
        <div class="distributor-section__contact">
          <p>M <a href="tel:+447930581224">07930 581224</a></p>
          <p>E <a href="mailto:info@coeursauvage.scot">info@coeursauvage.scot</a></p>
          <p><a href="https://coeursauvage.scot" target="_blank" rel="noopener noreferrer">coeursauvage.scot</a></p>
        </div>
      </article>

      <article class="distributor-section">
        <img src="/images/distributors/ochil-foods.png" alt="Ochil Foods" class="distributor-section__logo" loading="lazy" />
        <h3>Ochil Foods</h3>
        <p class="distributor-section__description">We're delighted to work with Ochil Foods, a cornerstone of Scotland's fine-food landscape. With a long-standing commitment to Scottish heritage and a distinguished reputation for quality, Ochil Foods connects independent producers with chefs across the country, championing the best of local and seasonal ingredients.</p>
        <div class="distributor-section__contact">
          <p>T <a href="tel:+441764662502">01764 662 502</a></p>
          <p>E <a href="mailto:orders@ochilfoods.co.uk">orders@ochilfoods.co.uk</a></p>
          <p><a href="https://ochilfoods.co.uk" target="_blank" rel="noopener noreferrer">ochilfoods.co.uk</a></p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .ws-hero {
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/banners/wholesale-banner.jpg');
    background-size: cover;
    background-position: 50% 30%;
    text-align: center;
  }

  .ws-hero h1 {
    font-size: 4rem;
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .ws-intro {
    max-width: 700px;
    margin-bottom: 3rem;
  }

  .ws-intro h2 {
    margin-bottom: 1rem;
  }

  .ws-intro p {
    color: var(--color-text-muted);
  }

  .distributor-section {
    max-width: 700px;
    margin-bottom: 3rem;
  }

  .distributor-section__logo {
    max-width: 200px;
    height: auto;
    margin-bottom: 1rem;
  }

  .distributor-section h3 {
    font-family: var(--font-heading);
    margin-bottom: 1rem;
  }

  .distributor-section__description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .distributor-section__contact {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .distributor-section__contact p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .distributor-section__contact a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 768px) {
    .ws-hero h1 {
      font-size: 6rem;
    }
  }
</style>
