---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';
import directSalesBannerSrc from '../assets/images/banners/direct-sales-banner.jpg';
import commercialBannerSrc from '../assets/images/banners/commercial-enquiries-banner.jpg';
import compostBannerSrc from '../assets/images/banners/compost-club-banner.jpg';

const directSalesBanner = await getImage({ src: directSalesBannerSrc, format: 'webp', quality: 80, width: 1920 });
const commercialBanner = await getImage({ src: commercialBannerSrc, format: 'webp', quality: 80, width: 1920 });
const compostBanner = await getImage({ src: compostBannerSrc, format: 'webp', quality: 80, width: 1920 });
---

<BaseLayout title="Contact — Glasgow Mushroom Company" description="Get in touch with Glasgow Mushroom Company.">
  <section class="contactus-section">
    <a href="/direct-sales" class="contactus-banner contactus-banner--direct-sales" style={`--bg: url('${directSalesBanner.src}')`}>
      <h1>Direct Sales</h1>
    </a>
  </section>

  <section class="contactus-section">
    <a href="/wholesale" class="contactus-banner contactus-banner--commercial" style={`--bg: url('${commercialBanner.src}')`}>
      <h1>Commercial Enquiries</h1>
    </a>
  </section>

  <section class="contactus-section contactus-section--bottom">
    <a href="https://compostclub.glasgowmushroom.co/" target="_blank" rel="noopener noreferrer" class="contactus-banner contactus-banner--compost" style={`--bg: url('${compostBanner.src}')`}>
      <h1>Compost Club</h1>
    </a>
  </section>
</BaseLayout>

<style>
  .contactus-section {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 400px;
    background-color: var(--color-bg);
  }

  .contactus-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1152px;
    max-width: 100%;
    height: 300px;
    background-size: cover;
    text-align: center;
    transition: opacity 0.3s ease;
  }

  .contactus-banner:hover {
    opacity: 0.9;
  }

  .contactus-banner h1 {
    font-size: 104px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #fff;
    text-transform: capitalize;
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  .contactus-banner--direct-sales {
    background-image: var(--bg);
    background-position: 50% 47%;
  }

  .contactus-banner--commercial {
    background-image: var(--bg);
    background-position: 50% 47%;
  }

  .contactus-banner--compost {
    background-image: var(--bg);
    background-position: 50% 57%;
  }

  @media (max-width: 767px) {
    .contactus-section {
      height: auto;
      padding: 1rem;
    }

    .contactus-banner {
      height: 200px;
    }

    .contactus-banner h1 {
      font-size: 3rem;
    }
  }
</style>
