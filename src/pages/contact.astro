---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Glasgow Mushroom Company" description="Get in touch with Glasgow Mushroom Company.">
  <section class="contact section">
    <div class="container">
      <h1>Contact</h1>

      <div class="contact__content">
        <p>For direct sales and orders over £50, please visit our <a href="/direct-sales">Direct Sales</a> page.</p>
        <p>For wholesale and distribution enquiries, visit our <a href="/wholesale">Wholesale</a> page.</p>
        <p>For general enquiries, you can reach us at:</p>

        <div class="contact__details">
          <p><a href="tel:+441412660377">0141 266 0377</a></p>
          <p><a href="mailto:hello@glasgowmushroomcompany.co.uk">hello@glasgowmushroomcompany.co.uk</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-top: 8rem;
  }

  .contact h1 {
    font-size: 3rem;
    margin-bottom: 2rem;
  }

  .contact__content {
    max-width: 600px;
  }

  .contact__content a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact__details {
    margin-top: 1.5rem;
  }

  .contact__details p {
    margin-bottom: 0.5rem;
  }

  .contact__details a {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .contact__details a:hover {
    color: var(--color-text);
    opacity: 1;
  }

  @media (min-width: 768px) {
    .contact {
      padding-top: 10rem;
    }
  }
</style>
