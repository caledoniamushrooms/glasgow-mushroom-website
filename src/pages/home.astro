---
import BaseLayout from '../layouts/BaseLayout.astro';
const mapsKey = import.meta.env.GOOGLE_MAPS_API_KEY;
---

<BaseLayout title="Home — Glasgow Mushroom Company">
  <section class="hero">
    <h1>Gourmet Mushrooms Grown In Glasgow</h1>
  </section>

  <section class="callout-grid">
    <a href="/products" class="callout-card">
      <h2>Products</h2>
      <p>Explore our range of gourmet mushrooms.</p>
      <span class="callout-card__btn">View Products</span>
    </a>

    <a href="/recipes" class="callout-card">
      <h2>Recipes</h2>
      <p>Delicious ways to cook with our mushrooms.</p>
      <span class="callout-card__btn">View Recipes</span>
    </a>

    <a href="/markets" class="callout-card">
      <h2>Markets & Workshops</h2>
      <p>Find us at local markets or join a workshop.</p>
      <span class="callout-card__btn">View Dates</span>
    </a>

    <a href="https://compostclub.glasgowmushroom.co" target="_blank" rel="noopener noreferrer" class="callout-card">
      <h2>Compost Club</h2>
      <p>Spent substrate collection for your garden.</p>
      <span class="callout-card__btn">Learn More</span>
    </a>

    <a href="/where-to-find-us" class="callout-card">
      <h2>Where To Find Us</h2>
      <p>Find our mushrooms at retailers across Glasgow.</p>
      <span class="callout-card__btn">View Stockists</span>
    </a>

    <a href="/wholesale" class="callout-card">
      <h2>Wholesale Customers</h2>
      <p>Access your account, place orders, and manage invoices.</p>
      <span class="callout-card__btn">Trade Login</span>
    </a>
  </section>

  <section class="instagram-feed">
    <h2>Follow Us</h2>
    <div class="instagram-feed__embed" id="instagram-embed">
      <!-- Behold Instagram widget — embed code to be added once account is set up -->
      <p class="instagram-feed__placeholder">
        Follow us on <a href="https://www.instagram.com/glasgowmushroomco/" target="_blank" rel="noopener noreferrer">@glasgowmushroomco</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  window.initMap = async function() {
    var mapLib = await google.maps.importLibrary("maps");
    var markerLib = await google.maps.importLibrary("marker");

    var map = new mapLib.Map(document.getElementById("map"), {
      mapId: "f036911d517a356e246f4d97",
      mapTypeControl: false,
      streetViewControl: false
    });

    var locs = [
      { lat: 55.8758, lng: -4.2933, name: "Roots, Fruits & Flowers",  logo: "/images/stockists/roots-fruits.jpg",     address: "455 Great Western Rd, Glasgow G12 8HH" },
      { lat: 55.8266, lng: -4.2511, name: "The Good Choice",           logo: "/images/stockists/the-good-choice.png", address: "1031 Cathcart Rd, Mt Florida, Glasgow G42 9XJ" },
      { lat: 55.8348, lng: -4.2573, name: "Locavore – Victoria Road",  logo: "/images/stockists/locavore.png",        address: "49 Victoria Rd, Glasgow G42 7SA" },
      { lat: 55.8723, lng: -4.3109, name: "Locavore – Dumbarton Road", logo: "/images/stockists/locavore.png",        address: "449 Dumbarton Rd, Partick, Glasgow G11 6EJ" },
      { lat: 55.8297, lng: -4.2740, name: "Zucchini – Nithsdale Road", logo: "/images/stockists/zucchini.jpg",        address: "28 Nithsdale Rd, Glasgow G41 5RB" },
      { lat: 55.8163, lng: -4.2475, name: "Zucchini – Clarkston Road", logo: "/images/stockists/zucchini.jpg",        address: "103 Clarkston Rd, Cathcart, Glasgow G44 3BL" }
    ];

    var bounds = new google.maps.LatLngBounds();
    var openInfo = null;

    for (var i = 0; i < locs.length; i++) {
      (function(loc) {
        var pos = {lat: loc.lat, lng: loc.lng};
        bounds.extend(pos);

        var marker = new markerLib.AdvancedMarkerElement({
          position: pos,
          map: map,
          title: loc.name,
          gmpClickable: true
        });

        var mapsUrl = 'https://www.google.com/maps?q=' + loc.lat + ',' + loc.lng;
        var content = [
          '<div style="display:flex;align-items:center;gap:10px;padding:4px 2px;min-width:220px">',
          '  <img src="' + loc.logo + '" style="width:56px;height:56px;object-fit:contain;flex-shrink:0;border-radius:4px">',
          '  <div>',
          '    <div style="font-size:13px;font-weight:700;margin-bottom:2px;color:#111">' + loc.name + '</div>',
          '    <div style="font-size:12px;color:#555;line-height:1.4;margin-bottom:6px">' + loc.address + '</div>',
          '    <a href="' + mapsUrl + '" target="_blank" rel="noopener noreferrer" style="font-size:11px;color:#1a73e8;text-decoration:none">View on Google Maps</a>',
          '  </div>',
          '</div>'
        ].join('');

        var info = new google.maps.InfoWindow({ headerDisabled: true, content: content });

        marker.addEventListener('gmp-click', function() {
          if (openInfo) openInfo.close();
          info.open({ map: map, anchor: marker });
          openInfo = info;
        });
      })(locs[i]);
    }

    map.fitBounds(bounds);

    map.addListener('click', function() {
      if (openInfo) { openInfo.close(); openInfo = null; }
    });
  };
</script>
<script is:inline define:vars={{ mapsKey }}>
  (function() {
    function loadMaps() {
      if (document.querySelector('script[src*="maps.googleapis.com"]')) return;
      var s = document.createElement('script');
      s.src = 'https://maps.googleapis.com/maps/api/js?key=' + mapsKey + '&callback=initMap';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }

    var consent = localStorage.getItem('cookie-consent');
    if (consent === 'accepted') {
      loadMaps();
    }
    window.addEventListener('cookie-consent', function(e) {
      if (e.detail === 'accepted') loadMaps();
    });
  })();
</script>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    background-image: url('/images/home-hero.jpg');
    background-size: auto;
    background-position: 58% 0;
    background-attachment: fixed;
    padding: 60px 0 0 40px;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero h1 {
    font-size: 160px;
    line-height: 159px;
    max-width: 50%;
    overflow: visible;
    text-transform: capitalize;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    animation: fadeUp 0.9s ease forwards;
  }

  .callout-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    background-color: var(--color-bg);
  }

  .callout-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    border: 1px solid hsl(142 71% 25%);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .callout-card:hover {
    border-color: hsl(142 71% 35%);
    background-color: rgba(255, 255, 255, 0.03);
  }

  .callout-card h2 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .callout-card p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .callout-card__btn {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    background-color: hsl(142 71% 25%);
    padding: 0.6rem 2rem;
    border-radius: 6px;
    transition: opacity 0.2s ease;
  }

  .callout-card:hover .callout-card__btn {
    opacity: 0.85;
  }

  .instagram-feed {
    text-align: center;
    padding: 3rem 1.5rem 4rem;
    background-color: var(--color-bg);
  }

  .instagram-feed h2 {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .instagram-feed__placeholder {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .instagram-feed__placeholder a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  :global(.info-window h3) {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
  }

  :global(.info-window p) {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
  }

  @media (max-width: 991px) {
    .hero h1 {
      font-size: 133px;
      line-height: 142px;
    }
  }

  @media (max-width: 767px) {
    .hero h1 {
      font-size: 99px;
      line-height: 100px;
    }
  }

  @media (max-width: 479px) {
    .hero {
      padding: 20px 0 60px 20px;
      background-position: 50% 11%;
    }

    .hero h1 {
      font-size: 54px;
      line-height: 72px;
      max-width: 51%;
    }

    .callout-grid {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem;
    }

    .callout-card h2 {
      font-size: 1.75rem;
    }
  }
</style>
