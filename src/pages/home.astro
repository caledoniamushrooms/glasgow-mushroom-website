---
import BaseLayout from '../layouts/BaseLayout.astro';
const mapsKey = import.meta.env.GOOGLE_MAPS_API_KEY;
---

<BaseLayout title="Home — Glasgow Mushroom Company">
  <section class="hero">
    <h1>Gourmet Mushrooms Grown In Glasgow</h1>
  </section>

  <a href="/products" class="cta-banner cta-banner--products">
    <h2>Products</h2>
  </a>

  <a href="/recipes" class="cta-banner cta-banner--recipes">
    <h2>Recipes</h2>
  </a>

  <div class="cta-banner cta-banner--stockists">
    <a href="/where-to-find-us" class="cta-banner__text">
      <h2>Where To Find Us</h2>
    </a>
    <div class="cta-banner__map" id="map"></div>
  </div>

  <section class="map-section">
    <!-- Map is rendered in the Where To Find Us banner above -->
  </section>
</BaseLayout>

<script is:inline>
  window.initMap = async function() {
    var mapLib = await google.maps.importLibrary("maps");
    var markerLib = await google.maps.importLibrary("marker");

    var map = new mapLib.Map(document.getElementById("map"), {
      mapId: "f036911d517a356e246f4d97",
      mapTypeControl: false,
      streetViewControl: false
    });

    var locs = [
      { lat: 55.8758, lng: -4.2933, name: "Roots, Fruits & Flowers",  logo: "/images/stockists/roots-fruits.jpg",     address: "455 Great Western Rd, Glasgow G12 8HH" },
      { lat: 55.8266, lng: -4.2511, name: "The Good Choice",           logo: "/images/stockists/the-good-choice.png", address: "1031 Cathcart Rd, Mt Florida, Glasgow G42 9XJ" },
      { lat: 55.8348, lng: -4.2573, name: "Locavore – Victoria Road",  logo: "/images/stockists/locavore.png",        address: "49 Victoria Rd, Glasgow G42 7SA" },
      { lat: 55.8723, lng: -4.3109, name: "Locavore – Dumbarton Road", logo: "/images/stockists/locavore.png",        address: "449 Dumbarton Rd, Partick, Glasgow G11 6EJ" },
      { lat: 55.8297, lng: -4.2740, name: "Zucchini – Nithsdale Road", logo: "/images/stockists/zucchini.jpg",        address: "28 Nithsdale Rd, Glasgow G41 5RB" },
      { lat: 55.8163, lng: -4.2475, name: "Zucchini – Clarkston Road", logo: "/images/stockists/zucchini.jpg",        address: "103 Clarkston Rd, Cathcart, Glasgow G44 3BL" }
    ];

    var bounds = new google.maps.LatLngBounds();
    var openInfo = null;

    for (var i = 0; i < locs.length; i++) {
      (function(loc) {
        var pos = {lat: loc.lat, lng: loc.lng};
        bounds.extend(pos);

        var marker = new markerLib.AdvancedMarkerElement({
          position: pos,
          map: map,
          title: loc.name,
          gmpClickable: true
        });

        var mapsUrl = 'https://www.google.com/maps?q=' + loc.lat + ',' + loc.lng;
        var content = [
          '<div style="display:flex;align-items:center;gap:10px;padding:4px 2px;min-width:220px">',
          '  <img src="' + loc.logo + '" style="width:56px;height:56px;object-fit:contain;flex-shrink:0;border-radius:4px">',
          '  <div>',
          '    <div style="font-size:13px;font-weight:700;margin-bottom:2px;color:#111">' + loc.name + '</div>',
          '    <div style="font-size:12px;color:#555;line-height:1.4;margin-bottom:6px">' + loc.address + '</div>',
          '    <a href="' + mapsUrl + '" target="_blank" rel="noopener noreferrer" style="font-size:11px;color:#1a73e8;text-decoration:none">View on Google Maps</a>',
          '  </div>',
          '</div>'
        ].join('');

        var info = new google.maps.InfoWindow({ headerDisabled: true, content: content });

        marker.addEventListener('gmp-click', function() {
          if (openInfo) openInfo.close();
          info.open({ map: map, anchor: marker });
          openInfo = info;
        });
      })(locs[i]);
    }

    map.fitBounds(bounds);

    map.addListener('click', function() {
      if (openInfo) { openInfo.close(); openInfo = null; }
    });
  };
</script>
<script is:inline define:vars={{ mapsKey }}>
  (function() {
    function loadMaps() {
      if (document.querySelector('script[src*="maps.googleapis.com"]')) return;
      var s = document.createElement('script');
      s.src = 'https://maps.googleapis.com/maps/api/js?key=' + mapsKey + '&callback=initMap';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }

    var consent = localStorage.getItem('cookie-consent');
    if (consent === 'accepted') {
      loadMaps();
    }
    window.addEventListener('cookie-consent', function(e) {
      if (e.detail === 'accepted') loadMaps();
    });
  })();
</script>

<style>
  .hero {
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    background-image: url('/images/splash-hero.jpg');
    background-size: auto;
    background-position: 58% 0;
    padding: 60px 0 0 40px;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero h1 {
    font-size: clamp(3rem, 12svh, 160px);
    max-width: 70vw;
    text-transform: capitalize;
    line-height: 1.05;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    animation: fadeUp 0.9s ease forwards;
  }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 400px;
    background-size: cover;
    text-align: center;
    transition: opacity 0.3s ease;
  }

  .cta-banner:hover {
    opacity: 0.9;
  }

  .cta-banner h2 {
    font-size: 140px;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: capitalize;
    color: var(--color-text);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    line-height: 1;
  }

  .cta-banner--products {
    background-image: url('/images/banners/products-banner.jpg');
    background-position: 50% 100%;
  }

  .cta-banner--recipes {
    background-image: url('/images/banners/recipes-banner.jpg');
    background-position: 50% 47%;
  }

  .cta-banner--stockists {
    background-color: var(--color-bg);
    display: flex;
    align-items: center;
    height: 460px;
    padding: 20px 0;
  }

  .cta-banner__text {
    flex: 1;
    text-align: center;
  }

  .cta-banner__text h2 {
    font-size: 81px;
  }

  .cta-banner__map {
    flex: 1;
    height: 320px;
    border-radius: 8px;
    margin-right: 40px;
  }

  .map-section {
    display: none;
  }

  :global(.info-window h3) {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
  }

  :global(.info-window p) {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
  }

  @media (max-width: 767px) {
    .hero {
      height: auto;
      min-height: 60vh;
      padding: 40px 1.5rem;
      background-size: cover;
      background-position: center;
    }

    .cta-banner {
      height: 200px;
    }

    .cta-banner h2 {
      font-size: 3rem;
    }

    .cta-banner--stockists {
      flex-direction: column;
      height: auto;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }

    .cta-banner__text h2 {
      font-size: 3rem;
    }

    .cta-banner__map {
      width: 100%;
      height: 300px;
    }
  }
</style>
