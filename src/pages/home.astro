    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .stockists-map__container {
    max-width: 100%;
    margin: 0;
    border-radius: 0;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .stockists-map__container {
      max-width: var(--container-max);
      margin: 0 auto;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    }
  }

  .stockists-map__canvas {
    width: 100%;
