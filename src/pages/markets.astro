---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';
import directSalesBannerSrc from '../assets/images/banners/direct-sales-banner.jpg';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

const today = new Date().toISOString().slice(0, 10);
const { data: rawEvents } = await supabase
  .from('market_events')
  .select('*, market_locations(*)')
  .gte('date', today)
  .order('date');

const months: Record<string, any[]> = {};
for (const event of rawEvents || []) {
  const d = new Date(event.date + 'T00:00:00');
  const key = d.toLocaleString('en-GB', { month: 'long', year: 'numeric' });
  if (!months[key]) months[key] = [];
  months[key].push({
    name: event.market_locations.name,
    type: event.market_locations.type,
    logoUrl: event.market_locations.logo_url,
    location: event.market_locations.address,
    locationUrl: event.market_locations.google_maps_url,
    time: `${event.start_time.slice(0, 5)} \u2013 ${event.end_time.slice(0, 5)}`,
    dayLabel: d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' }),
  });
}

const marketsHero = await getImage({ src: directSalesBannerSrc, format: 'webp', quality: 80, width: 1920 });
---

<BaseLayout title="Markets — Glasgow Mushroom Company" description="Find Glasgow Mushroom Company at local markets across Glasgow.">
  <section class="markets-hero" style={`--bg: url('${marketsHero.src}')`}>
    <h1>Markets</h1>
  </section>

  <section class="markets-content">
    <div class="markets-intro">
      <p>We love getting out and meeting people face to face. Find us at local markets across Glasgow — come say hello and grab some fresh mushrooms.</p>
    </div>

    {Object.entries(months).map(([month, events]) => (
      <div class="markets-month">
        <h2>{month}</h2>
        <div class="markets-grid">
          {events.map((event) => (
            <div class={`markets-card markets-card--${event.type}`}>
              <span class="markets-card__badge">{event.type}</span>
              {event.logoUrl && <img src={event.logoUrl} alt={event.name} class="markets-card__logo" width={140} loading="lazy" />}
              <p class="markets-card__date">{event.dayLabel}</p>
              <p class="markets-card__time">{event.time}</p>
              <p class="markets-card__location"><a href={event.locationUrl} target="_blank" rel="noopener noreferrer">{event.location}</a></p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>

<style is:global>
  body {
    background-color: #fff !important;
    color: #333 !important;
  }
  a {
    color: #333;
  }
  .header {
    background-color: var(--color-bg);
  }
  .header a,
  .header__nav-link,
  .header__dropdown-link {
    color: #fff;
  }
  footer {
    background-color: var(--color-bg-footer);
    color: #fff;
  }
  footer a {
    color: #fff;
  }
</style>

<style>
  .markets-hero {
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    /* TODO: Replace with dedicated markets banner image */
    background-image: var(--bg);
    background-size: cover;
    background-position: 50% 50%;
    text-align: center;
  }

  .markets-hero h1 {
    font-size: 100px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #fff;
    text-transform: capitalize;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .markets-content {
    padding: 40px 0 60px;
  }

  .markets-intro {
    width: 700px;
    max-width: 100%;
    margin: 20px auto 40px;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .markets-intro p {
    font-size: 20px;
    font-family: var(--font-heading);
    color: #333;
    line-height: 31px;
    text-align: center;
  }

  .markets-month {
    max-width: 900px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  .markets-month h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 1.25rem;
    border-bottom: 2px solid #e0e0e0;
    padding-bottom: 0.5rem;
  }

  .markets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .markets-card {
    background-color: #f8f8f8;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem;
    position: relative;
  }

  .markets-card__badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    background-color: hsl(142 71% 25%);
    color: #fff;
  }

  .markets-card__logo {
    display: block;
    max-width: 140px;
    margin: 0 auto 0.5rem;
  }

  .markets-card__date {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 0.25rem;
  }

  .markets-card__time {
    font-size: 0.9rem;
    color: #777;
    margin-bottom: 0.25rem;
  }

  .markets-card__location {
    font-size: 0.9rem;
    color: #777;
  }

  .markets-card__location a {
    color: #555;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .markets-card__location a:hover {
    color: #333;
  }

  @media (max-width: 767px) {
    .markets-hero {
      height: 200px;
    }

    .markets-hero h1 {
      font-size: 3rem;
    }

    .markets-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
