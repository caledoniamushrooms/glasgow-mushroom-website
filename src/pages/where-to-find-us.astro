---
import BaseLayout from '../layouts/BaseLayout.astro';
import StockistCard from '../components/StockistCard.astro';
import { stockists } from '../data/stockists.js';
---

<BaseLayout title="Where to find us — Glasgow Mushroom Company" description="Find Glasgow Mushroom Company products at these stockists and markets.">
  <section class="stockists-hero">
    <h1>Where to find us</h1>
  </section>

  <section class="stockists section">
    <div class="container">
      {stockists.map((stockist) => (
        <StockistCard {...stockist} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .stockists-hero {
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/banners/stockists-banner.jpg');
    background-size: cover;
    background-position: center;
    text-align: center;
  }

  .stockists-hero h1 {
    font-size: 100px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  @media (max-width: 767px) {
    .stockists-hero {
      height: 200px;
    }

    .stockists-hero h1 {
      font-size: 3rem;
    }
  }
</style>
