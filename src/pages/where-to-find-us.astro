---
import BaseLayout from '../layouts/BaseLayout.astro';
import StockistCard from '../components/StockistCard.astro';
import { stockists } from '../data/stockists.js';
---

<BaseLayout title="Where to find us — Glasgow Mushroom Company" description="Find Glasgow Mushroom Company products at these stockists and markets.">
  <section class="stockists-hero">
    <h1>Where to find us</h1>
  </section>

  <section class="stockists">
    {stockists.map((stockist) => (
      <StockistCard {...stockist} />
    ))}
  </section>
</BaseLayout>

<style>
  .stockists-hero {
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/banners/stockists-banner.jpg');
    background-size: cover;
    background-position: center;
    text-align: center;
  }

  .stockists-hero h1 {
    font-size: 100px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  @media (max-width: 767px) {
    .stockists-hero {
      height: 200px;
    }

    .stockists-hero h1 {
      font-size: 3rem;
    }
  }
</style>

<script>
  function equaliseStockistHeights() {
    const cards = document.querySelectorAll('.stockist-outer');
    if (!cards.length) return;

    // Reset heights first so we measure natural sizes
    cards.forEach(card => (card as HTMLElement).style.minHeight = '');

    // Only equalise above mobile breakpoint
    if (window.innerWidth <= 767) return;

    let maxHeight = 0;
    cards.forEach(card => {
      const height = (card as HTMLElement).offsetHeight;
      if (height > maxHeight) maxHeight = height;
    });

    cards.forEach(card => (card as HTMLElement).style.minHeight = `${maxHeight}px`);
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(equaliseStockistHeights, 150);
  });

  equaliseStockistHeights();
</script>
