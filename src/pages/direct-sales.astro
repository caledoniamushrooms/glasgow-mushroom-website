---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Direct Sales — Glasgow Mushroom Company" description="Order mushrooms directly from Glasgow Mushroom Company.">
  <section class="ds-hero">
    <h1>Direct Sales</h1>
  </section>

  <section class="ds-content">
    <div class="ds-flex">
      <div class="ds-intro">
        <p>We offer direct-to-customer sales for orders over £50 - if you have a big event planned or are just a mushroom lover looking to stock up please get in touch!</p>
        <p>For smaller quantites please check out our <a href="/where-to-find-us">where to find us</a> page for a list of local retailers.</p>
      </div>

      <div class="ds-form-card">
        <label class="form-title">Make an enquiry</label>
        <form method="POST" action="mailto:hello@glasgowmushroomcompany.co.uk" enctype="text/plain">
          <div class="form__field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Enter your name" required />
          </div>
          <div class="form__field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email address" required />
          </div>
          <div class="form__field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Hi, I would like to buy directly from you..." required></textarea>
          </div>
          <input type="submit" class="form__submit" value="Submit" />
        </form>
      </div>

      <div class="ds-contact">
        <p class="ds-contact__heading">Other ways to get in touch</p>
        <div class="ds-contact__icons">
          <a href="https://www.instagram.com/glasgowmushroomco/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <img src="/images/icons/instagram.png" alt="Instagram" width="70" height="70" />
          </a>
          <a href="https://wa.me/4401412660377" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <img src="/images/icons/whatsapp.svg" alt="WhatsApp" width="70" height="70" />
          </a>
          <a href="http://m.me/glasgowmushroomco" target="_blank" rel="noopener noreferrer" aria-label="Facebook Messenger">
            <img src="/images/icons/facebook-messenger.svg" alt="Facebook Messenger" width="70" height="70" />
          </a>
          <a href="mailto:hello@glasgowmushroomcompany.co.uk" aria-label="Email">
            <img src="/images/icons/email.svg" alt="Email" width="70" height="70" />
          </a>
        </div>
        <a href="tel:+441412660377" class="ds-contact__phone">0141 266 0377</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  body {
    background-color: #fff;
    color: #333;
  }
  a {
    color: #333;
  }
  .header {
    background-color: var(--color-bg);
  }
  .header a,
  .header__nav-link,
  .header__dropdown-link {
    color: #fff;
  }
  footer {
    background-color: var(--color-bg-footer);
    color: #fff;
  }
  footer a {
    color: #fff;
  }
</style>

<style>
  .ds-hero {
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/banners/direct-sales-banner.jpg');
    background-size: cover;
    background-position: 100% 31%;
    text-align: center;
  }

  .ds-hero h1 {
    font-size: 125px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #fff;
    text-transform: capitalize;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .ds-content {
    background-color: #fff;
    padding: 40px 0;
  }

  .ds-flex {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ds-intro {
    width: 700px;
    max-width: 100%;
    margin-top: 40px;
    margin-bottom: 0;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .ds-intro p {
    font-size: 20px;
    font-family: var(--font-heading);
    color: #333;
    line-height: 31px;
    margin-bottom: 1rem;
  }

  .ds-intro a {
    color: #333;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ds-form-card {
    background-color: rgb(224, 207, 183);
    border: 3px solid #333;
    border-radius: 12px;
    padding: 40px 40px 20px;
    width: 500px;
    max-width: calc(100% - 3rem);
    margin: 20px 0 15px;
    box-sizing: border-box;
  }

  .form-title {
    display: block;
    font-size: 38px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #333;
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .form__field {
    margin-bottom: 1rem;
  }

  .form__field label {
    display: block;
    font-size: 14px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #333;
    margin-bottom: 0.4rem;
  }

  .form__field input,
  .form__field textarea {
    width: 100%;
    padding: 8px 12px;
    background-color: #fff;
    border: 1px solid #ccc;
    border-radius: 4px;
    color: #333;
    font-family: var(--font-body);
    font-size: 14px;
    box-sizing: border-box;
  }

  .form__field input:focus,
  .form__field textarea:focus {
    outline: none;
    border-color: #888;
  }

  .form__submit {
    display: block;
    padding: 10px 2rem;
    background-color: #333;
    color: #fff;
    border: none;
    border-radius: 5px;
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .form__submit:hover {
    opacity: 0.85;
  }

  .ds-contact {
    width: 375px;
    max-width: calc(100% - 3rem);
    margin: 20px 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ds-contact__heading {
    font-size: 27px;
    font-family: var(--font-heading);
    color: #000;
    margin-bottom: 1rem;
    text-align: center;
  }

  .ds-contact__icons {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .ds-contact__icons a {
    display: block;
    transition: opacity 0.2s ease;
  }

  .ds-contact__icons a:hover {
    opacity: 0.7;
  }

  .ds-contact__icons img {
    display: block;
    width: 70px;
    height: 70px;
    object-fit: contain;
  }

  .ds-contact__phone {
    display: block;
    color: #000;
    font-size: 14px;
    font-family: Arial, sans-serif;
    text-decoration: none;
  }

  @media (max-width: 767px) {
    .ds-hero {
      height: 200px;
    }

    .ds-hero h1 {
      font-size: 3rem;
    }

    .ds-form-card {
      padding: 1.5rem;
    }
  }
</style>
