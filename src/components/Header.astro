---
import { navItems } from '../data/navigation.js';
---

<header class="header">
  <div class="header__inner container">
    <a href="/home" class="header__logo" aria-label="Glasgow Mushroom Company home">
      <img src="/images/logo-full.svg" alt="Glasgow Mushroom Company" width="144" height="60" class="header__logo-img" />
    </a>

    <button class="header__hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>

    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list">
        {navItems.map((item) => (
          <li class={item.children ? 'header__nav-item--has-dropdown' : ''}>
            <a
              href={item.href}
              class="header__nav-link"
              {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {item.label}
            </a>
            {item.children && (
              <ul class="header__dropdown">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class="header__dropdown-link">{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li>
          <a href="/portal/login" class="header__trade-login" aria-label="Trade customer login" title="Trade Login">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/>
              <path d="M20 21a8 8 0 0 0-16 0"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const hamburger = document.querySelector('.header__hamburger');
  const nav = document.querySelector('.header__nav');

  hamburger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Dropdown with hide delay so mouse can travel from link to menu
  document.querySelectorAll('.header__nav-item--has-dropdown').forEach((item) => {
    const dropdown = item.querySelector('.header__dropdown');
    let hideTimer: ReturnType<typeof setTimeout> | null = null;

    const show = () => {
      if (hideTimer) clearTimeout(hideTimer);
      dropdown?.classList.add('is-visible');
    };

    const hide = () => {
      hideTimer = setTimeout(() => {
        dropdown?.classList.remove('is-visible');
      }, 200);
    };

    item.addEventListener('mouseenter', show);
    item.addEventListener('mouseleave', hide);
  });
</script>

<style>
  .header {
    background-color: var(--color-bg);
    position: relative;
    z-index: 100;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 120px;
  }

  .header__logo {
    display: inline-block;
    transition: transform 0.2s ease-in-out;
  }

  .header__logo:hover {
    transform: scale(1.05);
    opacity: 1;
  }

  .header__logo img {
    display: block;
  }

  .header__logo-img {
    filter: invert(1);
  }

  /* Trade login icon */
  .header__trade-login {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    color: var(--color-text);
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .header__trade-login:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
    opacity: 1;
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
  }

  .header__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Nav */
  .header__nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .header__nav.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .header__nav-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .header__nav-link {
    font-family: var(--font-heading);
    font-size: var(--nav-link-size);
    font-weight: 400;
    display: inline-block;
    transition: transform 0.2s ease-in-out;
  }

  .header__nav-link:hover {
    transform: scale(1.1);
    opacity: 1;
  }

  /* Dropdown — mobile: show sub-items inline */
  .header__nav-item--has-dropdown {
    text-align: center;
  }

  .header__dropdown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .header__dropdown-link {
    font-family: var(--font-heading);
    font-size: calc(var(--nav-link-size) - 2px);
    font-weight: 700;
    color: var(--color-text-muted);
    display: inline-block;
    transition: transform 0.2s ease-in-out, color 0.2s ease-in-out;
  }

  .header__dropdown-link:hover {
    transform: scale(1.1);
    color: var(--color-text);
    opacity: 1;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .header__hamburger {
      display: none;
    }

    .header__nav {
      position: static;
      opacity: 1;
      pointer-events: auto;
      background: none;
    }

    .header__nav-list {
      flex-direction: row;
      gap: 2rem;
    }

    /* Dropdown — desktop: show on hover */
    .header__nav-item--has-dropdown {
      position: relative;
    }

    .header__dropdown {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background-color: var(--color-bg-footer);
      border-radius: 8px;
      padding: 1.75rem 1.5rem 1rem;
      min-width: 160px;
      align-items: flex-start;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease 0.1s;
    }

    .header__dropdown.is-visible {
      opacity: 1;
      pointer-events: auto;
      transition-delay: 0s;
    }

    .header__dropdown-link {
      font-size: 0.9rem;
      white-space: nowrap;
    }
  }
</style>
