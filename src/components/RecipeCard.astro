---
interface Props {
  name: string;
  image: string;
  description: string;
  ingredients: string[];
  method: string;
}

const { name, image, description, ingredients, method } = Astro.props;
---

<article class="recipe-section">
  <div class="recipe-section__image">
    <img src={image} alt={name} loading="lazy" />
  </div>
  <div class="recipe-section__card">
    <h2>{name}</h2>
    <p class="recipe-section__description">{description}</p>

    <div class="recipe-section__details">
      <div class="recipe-section__ingredients">
        <h3>Ingredients</h3>
        <ul>
          {ingredients.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="recipe-section__method">
        <h3>Method</h3>
        <p>{method}</p>
      </div>
    </div>
  </div>
</article>

<style>
  .recipe-section {
    margin-bottom: 3rem;
  }

  .recipe-section__image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .recipe-section__card {
    background-color: #ffffff;
    color: #1a1a1a;
    padding: 2rem;
    border-radius: 8px;
    margin-top: -2rem;
    position: relative;
    max-width: 90%;
    margin-left: auto;
    margin-right: auto;
  }

  .recipe-section__card h2 {
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .recipe-section__description {
    color: #444;
  }

  .recipe-section__details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .recipe-section__details h3 {
    color: #1a1a1a;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .recipe-section__ingredients ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  .recipe-section__ingredients li {
    margin-bottom: 0.4rem;
    color: #444;
    font-size: 0.95rem;
  }

  .recipe-section__method p {
    color: #444;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .recipe-section__details {
      grid-template-columns: 1fr 2fr;
    }
  }
</style>
