---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  name: string;
  image: ImageMetadata;
  description: string;
  ingredients: string[];
  method: string;
}

const { name, image, description, ingredients, method } = Astro.props;
---

<section class="recipe-section">
  <div class="recipe-grid">
    <Image class="recipe-image" src={image} alt={name} width={800} format="webp" quality={80} loading="lazy" />
    <div class="recipe-right">
      <h2 class="recipe-title">{name}</h2>
      <p class="recipe-subscript">{description}</p>
      <h3 class="recipe-heading">Ingredients</h3>
      <div class="recipe-ingredients">
        {ingredients.map((item) => <p class="recipe-ingredient">{item}</p>)}
      </div>
      <h3 class="recipe-heading">Method</h3>
      <div class="recipe-method">{method}</div>
    </div>
  </div>
</section>

<style>
  .recipe-section {
    width: 100%;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
  }

  .recipe-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recipe-right {
    padding: 0 56px;
    display: flex;
    flex-direction: column;
    color: #333;
  }

  .recipe-title {
    font-size: 31px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #333;
    line-height: 1.1;
    margin: 20px 0 10px;
  }

  .recipe-subscript {
    font-size: 14px;
    font-family: var(--font-heading);
    font-style: italic;
    color: #333;
    line-height: 1.5;
    margin-bottom: 0;
  }

  .recipe-heading {
    font-size: 31px;
    font-family: var(--font-heading);
    font-weight: 700;
    color: #333;
    line-height: 1.1;
    margin: 20px 0 10px;
  }

  .recipe-ingredient {
    font-size: 14px;
    font-family: var(--font-heading);
    color: #333;
    margin-bottom: 0.25rem;
  }

  .recipe-method {
    font-size: 20px;
    font-family: var(--font-heading);
    color: #333;
    line-height: 1.65;
    margin-bottom: 100px;
  }

  @media (max-width: 767px) {
    .recipe-grid {
      grid-template-columns: 1fr;
    }

    .recipe-image {
      height: 300px;
    }

    .recipe-right {
      padding: 1.5rem;
    }

    .recipe-title,
    .recipe-heading {
      font-size: 1.75rem;
    }

    .recipe-method {
      font-size: 1rem;
      margin-bottom: 3rem;
    }
  }
</style>
