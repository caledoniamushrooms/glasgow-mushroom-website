---
interface Props {
  name: string;
  image: string;
  description: string;
  ingredients: string[];
  method: string[];
}

const { name, image, description, ingredients, method } = Astro.props;
---

<article class="recipe-card">
  <div class="recipe-card__image">
    <img src={image} alt={name} loading="lazy" />
  </div>
  <div class="recipe-card__content">
    <h3>{name}</h3>
    <p>{description}</p>

    <div class="recipe-card__details">
      <div class="recipe-card__ingredients">
        <h4>Ingredients</h4>
        <ul>
          {ingredients.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="recipe-card__method">
        <h4>Method</h4>
        <ol>
          {method.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</article>

<style>
  .recipe-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 8px;
    background-color: var(--color-bg-footer);
    margin-bottom: 2rem;
  }

  .recipe-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .recipe-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recipe-card__content {
    padding: 1.5rem;
  }

  .recipe-card__content h3 {
    font-family: var(--font-heading);
    margin-bottom: 0.75rem;
  }

  .recipe-card__details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .recipe-card__details h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .recipe-card__ingredients ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  .recipe-card__ingredients li,
  .recipe-card__method li {
    margin-bottom: 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .recipe-card__method ol {
    list-style: decimal;
    padding-left: 1.25rem;
  }

  @media (min-width: 768px) {
    .recipe-card__details {
      grid-template-columns: 1fr 2fr;
    }
  }
</style>
