---
interface Props {
  name: string;
  scientificName: string;
  image: string;
  description: string;
  tastingProfile: string;
}

const { name, scientificName, image, description, tastingProfile } = Astro.props;
---

<article class="product-section">
  <div class="product-section__image" style={`background-image: url('${image}')`}></div>
  <div class="product-section__content">
    <h2>{name}</h2>
    <p class="product-section__scientific-name">{scientificName}</p>
    <p>{description}</p>
    <p class="product-section__tasting"><strong>Tasting Notes:</strong> {tastingProfile}</p>
  </div>
</article>

<style>
  .product-section {
    margin-bottom: 2rem;
  }

  .product-section__image {
    width: 100%;
    height: 400px;
    background-size: cover;
    background-position: center;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .product-section__content {
    max-width: 700px;
  }

  .product-section h2 {
    margin-bottom: 0.25rem;
  }

  .product-section__scientific-name {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .product-section__tasting {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
