---
interface Address {
  text: string;
  mapUrl: string;
}

interface Props {
  name: string;
  logo: string;
  description: string;
  addresses: Address[];
  bgColor?: string;
  textColor?: string;
  headingColor?: string;
}

const { name, logo, description, addresses, bgColor = '#000000', textColor = '#ffffff', headingColor } = Astro.props;
const titleColor = headingColor || textColor;
---

<section class="stockist-outer" style={`background-color: ${bgColor}`}>
  <div class="stockist-card">
    <div class="stockist-card__inner">
      <div class="stockist-card__logo-col">
        <img src={logo} alt={name} class="stockist-card__logo" loading="lazy" />
      </div>
      <div class="stockist-card__content" style={`color: ${titleColor}`}>
        <h2 class="stockist-card__name">{name}</h2>
        <p class="stockist-card__desc">{description}</p>
        <div class="stockist-card__addresses">
          {addresses.map((addr) => (
            <a href={addr.mapUrl} target="_blank" rel="noopener noreferrer" class="stockist-card__address">{addr.text}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stockist-outer {
    width: 100%;
  }

  .stockist-card {
    max-width: 1088px;
    margin: 0 auto;
    padding: 60px 40px;
    box-sizing: border-box;
  }

  .stockist-card__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 3rem;
  }

  .stockist-card__logo-col {
    flex: 0 0 265px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stockist-card__logo {
    max-width: 265px;
    max-height: 200px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .stockist-card__content {
    flex: 1;
    min-width: 0;
  }

  .stockist-card__name {
    font-size: 60px;
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .stockist-card__desc {
    font-size: 20px;
    font-family: var(--font-heading);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .stockist-card__addresses {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stockist-card__address {
    display: block;
    font-size: 18px;
    font-family: var(--font-heading);
    text-decoration: none;
    color: inherit;
    opacity: 0.85;
  }

  .stockist-card__address:hover {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .stockist-card {
      padding: 1.5rem;
    }

    .stockist-card__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .stockist-card__logo-col {
      flex: none;
      width: 100%;
      justify-content: flex-start;
    }

    .stockist-card__logo {
      max-width: 180px;
    }

    .stockist-card__name {
      font-size: 2rem;
    }
  }
</style>
