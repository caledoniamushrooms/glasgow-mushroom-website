---
import SocialIcons from './SocialIcons.astro';
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__grid">
      <div class="footer__section">
        <div class="footer__heading">Site Map</div>
        <a href="/products" class="footer__link">Products</a>
        <a href="/recipes" class="footer__link">Recipes</a>
        <a href="/where-to-find-us" class="footer__link">Where to find us</a>
        <a href="/contact" class="footer__link">Contact</a>
      </div>

      <div class="footer__section">
        <div class="footer__heading">About</div>
        <a href="/privacy-policy" class="footer__link">Privacy policy</a>
        <a href="tel:+441412660377" class="footer__link">0141 266 0377</a>
        <div class="footer__social">
          <SocialIcons />
        </div>
      </div>
    </div>

    <div class="footer__divider"></div>

    <div class="footer__bottom">
      <p>Copyright &copy; {new Date().getFullYear()} Glasgow Mushroom Co.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-footer);
    padding: 50px 0 15px;
  }

  .footer__inner {
    max-width: 1152px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer__grid {
    display: flex;
    gap: 8rem;
    justify-content: center;
  }

  .footer__section {
    display: flex;
    flex-direction: column;
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #f7f7f7;
    margin-bottom: 28px;
  }

  .footer__link {
    display: block;
    font-family: var(--font-heading);
    font-size: 18px;
    color: rgb(180, 180, 180);
    margin-bottom: 28px;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: #fff;
    opacity: 1;
  }

  .footer__social {
    margin-top: 0.75rem;
  }

  .footer__divider {
    height: 2px;
    background-color: rgb(228, 235, 243);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .footer__bottom p {
    color: #fff;
    font-size: 14px;
    font-family: Arial, sans-serif;
    text-align: center;
    margin: 0;
  }
</style>
