---
interface Props {
  src: string;
  title?: string;
}

const { src, title = 'Map' } = Astro.props;
---

<div class="map-embed">
  <iframe
    src={src}
    title={title}
    width="100%"
    height="100%"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

<style>
  .map-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    border-radius: 8px;
    overflow: hidden;
  }

  .map-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
</style>
